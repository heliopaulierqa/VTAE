# VTAE — variáveis de ambiente globais
# Copie para .env e preencha com os valores reais.
# Este arquivo pode ser commitado. O .env nunca deve ser commitado.

# ──────────────────────────────────────────────────────────────
# SMTP — configuração de e-mail para vtae send
# ──────────────────────────────────────────────────────────────

# Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@gmail.com
# SMTP_PASS=sua_app_password   ← não é a senha da conta Google
# SMTP_SSL=false               ← Gmail usa TLS (não SSL)
#
# Para criar App Password no Gmail:
#   https://myaccount.google.com/apppasswords

# Outlook / Office 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=seu@outlook.com
# SMTP_PASS=sua_senha
# SMTP_SSL=false

# SMTP corporativo
# SMTP_HOST=smtp.incor.org.br
# SMTP_PORT=587
# SMTP_USER=vtae@incor.org.br
# SMTP_PASS=sua_senha
# SMTP_SSL=false

# ──────────────────────────────────────────────────────────────
# Ambiente padrão (sobrescrito pelo --env da CLI)
# ──────────────────────────────────────────────────────────────
# VTAE_ENV=dev
